# ---------------------------------------------------------------------------
# GROUP: plugin
# ---------------------------------------------------------------------------
group_plugin() {
    should_run_group "plugin" || return 0
    group_header "Plugin Commands"

    # Create a temp fixture directory with fake plugin dirs
    local PLUGIN_FIXTURE_DIR
    PLUGIN_FIXTURE_DIR=$(mktemp -d)
    trap "rm -rf '$PLUGIN_FIXTURE_DIR'" RETURN

    # Create a valid plugin directory with plugin.toml
    mkdir -p "$PLUGIN_FIXTURE_DIR/test-infill"
    cat > "$PLUGIN_FIXTURE_DIR/test-infill/plugin.toml" << 'TOML'
library_filename = "libtest_infill.so"
plugin_type = "native"
capabilities = ["infill_pattern"]

[metadata]
name = "test-infill"
version = "1.0.0"
description = "A test infill plugin for QA"
author = "QA Test"
license = "MIT"
min_api_version = "0.0.0"
max_api_version = "99.99.99"
TOML

    # Create a second valid plugin (postprocessor)
    mkdir -p "$PLUGIN_FIXTURE_DIR/test-postproc"
    cat > "$PLUGIN_FIXTURE_DIR/test-postproc/plugin.toml" << 'TOML'
library_filename = "libtest_postproc.so"
plugin_type = "native"
capabilities = ["gcode_post_processor"]

[metadata]
name = "test-postproc"
version = "2.0.0"
description = "A test post-processor plugin"
author = "QA Test"
license = "MIT"
min_api_version = "0.0.0"
max_api_version = "99.99.99"
TOML

    # --- List commands ---
    run_test "plugins list (table)" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list

    run_test "plugins list --json" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list --json

    run_test "plugins list --category infill" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list --category infill

    run_test "plugins list --status enabled" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list --status enabled

    # --- Info command ---
    run_test "plugins info test-infill" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" info test-infill

    run_test "plugins info --json" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" info test-infill --json

    # --- Disable/Enable cycle ---
    run_test "plugins disable test-infill" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" disable test-infill

    # Verify .status file was written
    run_test "verify .status file exists after disable" \
        test -f "$PLUGIN_FIXTURE_DIR/test-infill/.status"

    run_test "plugins list shows disabled" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list --status disabled

    # Enable succeeds (manifest + version validated, no actual .so load required)
    run_test "plugins enable test-infill" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" enable test-infill

    # --- Validate command ---
    # validate fails on load (no .so), but runs manifest/version checks first
    run_test_expect_fail "plugins validate (no library)" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" validate test-infill

    # --- Error cases ---
    run_test_expect_fail "plugins info nonexistent plugin" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" info nonexistent-plugin

    run_test_expect_fail "plugins enable nonexistent plugin" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" enable nonexistent-plugin

    run_test_expect_fail "plugins disable nonexistent plugin" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" disable nonexistent-plugin

    run_test_expect_fail "plugins list no --plugin-dir" \
        "$SLICECORE" plugins list

    # --- Broken plugin listing (should not crash) ---
    # Add a broken plugin directory AFTER enable/disable cycle (enable calls
    # discover_plugins on parent dir, and broken manifests cause validation errors)
    mkdir -p "$PLUGIN_FIXTURE_DIR/broken-plugin"
    echo "this is {{{ not valid toml" > "$PLUGIN_FIXTURE_DIR/broken-plugin/plugin.toml"

    run_test "plugins list includes broken plugin without crashing" \
        "$SLICECORE" plugins --plugin-dir "$PLUGIN_FIXTURE_DIR" list
}

# ---------------------------------------------------------------------------
# GROUP: errors
# ---------------------------------------------------------------------------
group_errors() {
    should_run_group "errors" || return 0
    group_header "Error Handling"

    run_test_expect_fail "slice nonexistent file" \
        "$SLICECORE" slice nonexistent.stl

    run_test_expect_fail "validate nonexistent file" \
        "$SLICECORE" validate nonexistent.gcode

    run_test_expect_fail "convert nonexistent file" \
        "$SLICECORE" convert nonexistent.stl out.3mf

    run_test_expect_fail "csg union with no args" \
        "$SLICECORE" csg union

    run_test_expect_fail "analyze nonexistent file" \
        "$SLICECORE" analyze nonexistent.stl

    run_test_expect_fail "csg primitive box (no --dims, no -o)" \
        "$SLICECORE" csg primitive box

    run_test_expect_fail "csg split with invalid plane" \
        "$SLICECORE" csg split "$TMPDIR_QA/cube.stl" --plane invalid

    run_test_expect_fail "calibrate nonexistent subcommand" \
        "$SLICECORE" calibrate nonexistent

    run_test_expect_fail "schema with invalid tier" \
        "$SLICECORE" schema --tier nonexistent

    run_test_expect_fail "schema with invalid format" \
        "$SLICECORE" schema --format nonexistent

    run_test_expect_fail "convert-profile nonexistent file" \
        "$SLICECORE" convert-profile nonexistent.json

    # slicecore with no subcommand -- should print help, may exit 0 or 2
    local output exit_code
    output=$("$SLICECORE" 2>&1) && exit_code=0 || exit_code=$?
    if echo "$output" | grep -qi "usage\|commands\|help"; then
        pass "no subcommand prints help (exit $exit_code)"
    else
        fail "no subcommand did not print help" "exit $exit_code"
    fi
}

# ---------------------------------------------------------------------------
# GROUP: coverage
# ---------------------------------------------------------------------------
group_coverage() {
    should_run_group "coverage" || return 0
    group_header "Coverage Gap Report"

    # Map crates to CLI subcommands
    declare -A CRATE_MAP
    CRATE_MAP["slicecore-engine"]="slice, analyze"
    CRATE_MAP["slicecore-fileio"]="convert, analyze"
    CRATE_MAP["slicecore-gcode-io"]="validate, analyze-gcode, compare-gcode"
    CRATE_MAP["slicecore-mesh"]="csg"
    CRATE_MAP["slicecore-ai"]="ai-suggest"
    CRATE_MAP["slicecore-plugin"]="plugins"
    CRATE_MAP["slicecore-render"]="thumbnail"
    CRATE_MAP["slicecore-slicer"]="slice (internal)"
    CRATE_MAP["slicecore-cli"]="(the CLI itself)"
    CRATE_MAP["slicecore-arrange"]="arrange"
    CRATE_MAP["slicecore-plugin-api"]="(plugin API, no direct subcommand)"
    CRATE_MAP["slicecore-geo"]="(geometry primitives, no direct subcommand)"
    CRATE_MAP["slicecore-math"]="(math utilities, no direct subcommand)"
    CRATE_MAP["slicecore-config-schema"]="schema"
    CRATE_MAP["slicecore-config-derive"]="(proc-macro, no direct subcommand)"

    # Get list of crates
    local crates_dir="$PROJECT_ROOT/crates"
    local crates
    crates=$(ls -1 "$crates_dir" 2>/dev/null || echo "")

    # Get CLI subcommands
    local subcommands
    subcommands=$("$SLICECORE" --help 2>&1 | sed -n '/^Commands:/,/^$/p' | tail -n +2 | awk '{print $1}' | grep -v '^$' || true)

    printf '\n  %-25s %-45s %s\n' "Crate" "CLI Exposure" "Status"
    printf '  %-25s %-45s %s\n' "-------------------------" "---------------------------------------------" "--------"

    local no_exposure_count=0
    for crate in $crates; do
        local exposure="${CRATE_MAP[$crate]:-unknown}"
        local status

        if [[ "$exposure" == *"no direct subcommand"* ]] || [[ "$exposure" == *"the CLI itself"* ]] || [[ "$exposure" == *"internal"* ]]; then
            status="INTERNAL"
            no_exposure_count=$((no_exposure_count + 1))
        elif [[ "$exposure" == "unknown" ]]; then
            status="UNMAPPED"
            no_exposure_count=$((no_exposure_count + 1))
        else
            status="EXPOSED"
        fi
        printf '  %-25s %-45s %s\n' "$crate" "$exposure" "$status"
    done

    # Count public modules per crate
    printf '\n  %-25s %s\n' "Crate" "Public Modules"
    printf '  %-25s %s\n' "-------------------------" "--------------"
    for crate in $crates; do
        local lib_rs="$crates_dir/$crate/src/lib.rs"
        if [[ -f "$lib_rs" ]]; then
            local pub_mod_count
            pub_mod_count=$(grep -c 'pub mod' "$lib_rs" 2>/dev/null) || pub_mod_count=0
            printf '  %-25s %s\n' "$crate" "$pub_mod_count"
        fi
    done

    info "Crates without direct CLI subcommand exposure: $no_exposure_count"
    info "Coverage report complete -- see table above"
}

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
print_summary() {
    local total=$((PASS_COUNT + FAIL_COUNT + WARN_COUNT + INFO_COUNT))
    printf '\n%s\n' "$(bold "=== QA Test Summary ===")"
    printf '%s: %d\n' "$(green "PASS")" "$PASS_COUNT"
    printf '%s: %d\n' "$(red "FAIL")" "$FAIL_COUNT"
    printf '%s: %d\n' "$(yellow "WARN")" "$WARN_COUNT"
    printf '%s: %d\n' "$(cyan "INFO")" "$INFO_COUNT"
    printf 'Total: %d\n' "$total"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
    parse_args "$@"
    setup

    # Determine if we need fixtures
    local needs_fixtures=false
    for g in mesh slice travel-opt global-flags gcode csg convert thumbnail arrange postprocess errors; do
        if should_run_group "$g"; then
            needs_fixtures=true
            break
        fi
    done

    # Check disk space before build
    check_disk_space "pre-build" || { print_summary; exit 1; }

    # Build group first (if requested)
    group_build

    # Benchmarks (after build, before functional tests)
    group_bench

    # Ensure binary is available
    ensure_binary || { print_summary; exit 1; }

    # Generate fixtures if needed
    if $needs_fixtures; then
        generate_fixtures || { print_summary; exit 1; }
    fi

    # Run test groups
    group_mesh
    group_slice
    group_travel_opt
    group_global_flags
    group_gcode
    group_csg
    group_convert
    group_thumbnail
    group_arrange
    group_profile
    group_postprocess
    group_calibrate
    group_schema
    group_ai
    group_plugin
    group_errors
    group_coverage

    # Post-test disk space check
    check_disk_space "post-test"

    # Summary
    print_summary
    report_stale_qa_dirs

    if [[ $FAIL_COUNT -gt 0 ]]; then
        exit 1
    fi
    exit 0
}

main "$@"
