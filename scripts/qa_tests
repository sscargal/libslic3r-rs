#!/usr/bin/env bash
# =============================================================================
# slicecore CLI QA Test Script
# =============================================================================
#
# Comprehensive end-to-end QA test suite that exercises every slicecore
# CLI subcommand, runs build gates, and reports coverage gaps.
#
# Usage:
#   scripts/qa_tests [OPTIONS]
#
# Options:
#   --group GROUP   Run only named group(s), comma-separated
#   --skip GROUP    Skip named group(s), comma-separated
#   --list-groups   Print available groups and exit
#   --no-color      Disable ANSI color output
#   --verbose       Show stdout/stderr from commands (default: suppress on pass)
#   --disk-threshold N  Percent disk usage that triggers cleanup (default: 90)
#   --help          Show this help message
#
# Groups:
#   build       Build gates (cargo build, fmt, clippy, test, doc)
#   bench       Criterion benchmarks (cargo bench --workspace)
#   mesh        Mesh analysis commands
#   slice       Slicing operations
#   gcode       G-code analysis and comparison
#   csg         CSG boolean operations and primitives
#   convert     File format conversion
#   thumbnail   Thumbnail preview generation
#   arrange     Build plate arrangement
#   profile     Profile listing and search
#   postprocess Post-processing operations
#   ai          AI suggestion commands
#   plugin      Plugin commands
#   errors      Error handling / edge cases
#   coverage    Coverage gap report
#
# Environment:
#   SLICECORE_BIN       Path to pre-built slicecore binary (skips build)
#   DISK_THRESHOLD      Percent disk usage threshold (overridden by --disk-threshold)
#
# =============================================================================

set -euo pipefail

# ---------------------------------------------------------------------------
# Globals
# ---------------------------------------------------------------------------
PASS_COUNT=0
FAIL_COUNT=0
WARN_COUNT=0
INFO_COUNT=0

ONLY_GROUPS=""
SKIP_GROUPS=""
NO_COLOR=false
VERBOSE=false
TMPDIR_QA=""
DISK_THRESHOLD="${DISK_THRESHOLD:-90}"

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Default: use debug binary after build
SLICECORE="${SLICECORE_BIN:-}"

ALL_GROUPS="build bench mesh slice travel-opt global-flags gcode csg convert thumbnail arrange profile profile-manage profile-activate postprocess calibrate schema ai plugin errors coverage"

# ---------------------------------------------------------------------------
# Color helpers
# ---------------------------------------------------------------------------
_color() {
    if $NO_COLOR; then
        printf '%s' "$2"
    else
        printf '%s%s%s' "$1" "$2" $'\033[0m'
    fi
}

green()  { _color $'\033[32m' "$1"; }
red()    { _color $'\033[31m' "$1"; }
yellow() { _color $'\033[33m' "$1"; }
cyan()   { _color $'\033[36m' "$1"; }
bold()   { _color $'\033[1m'  "$1"; }

# ---------------------------------------------------------------------------
# Result reporters
# ---------------------------------------------------------------------------
pass() {
    PASS_COUNT=$((PASS_COUNT + 1))
    printf '  [%s] %s\n' "$(green "PASS")" "$1"
}

fail() {
    FAIL_COUNT=$((FAIL_COUNT + 1))
    printf '  [%s] %s\n' "$(red "FAIL")" "$1"
    if [[ -n "${2:-}" ]]; then
        printf '         %s\n' "$2"
    fi
}

warn() {
    WARN_COUNT=$((WARN_COUNT + 1))
    printf '  [%s] %s\n' "$(yellow "WARN")" "$1"
}

info() {
    INFO_COUNT=$((INFO_COUNT + 1))
    printf '  [%s] %s\n' "$(cyan "INFO")" "$1"
}

# ---------------------------------------------------------------------------
# Test runners
# ---------------------------------------------------------------------------

# run_test "description" command [args...]
# Expects command to succeed (exit 0).
run_test() {
    local desc="$1"; shift
    local output exit_code
    output=$("$@" 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        pass "$desc"
        if $VERBOSE; then
            printf '%s\n' "$output" | sed 's/^/         /'
        fi
    else
        fail "$desc" "exit code $exit_code"
        printf '%s\n' "$output" | tail -10 | sed 's/^/         /'
    fi
    return 0
}

# run_test_expect_fail "description" command [args...]
# Expects command to fail (non-zero exit).
run_test_expect_fail() {
    local desc="$1"; shift
    local output exit_code
    output=$("$@" 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        pass "$desc (expected failure, got exit $exit_code)"
    else
        fail "$desc" "expected non-zero exit, got 0"
        if $VERBOSE; then
            printf '%s\n' "$output" | tail -5 | sed 's/^/         /'
        fi
    fi
    return 0
}

# run_test_json "description" command [args...]
# Expects command to succeed and produce valid JSON on stdout.
# Note: captures stdout separately from stderr so progress/log messages
# don't pollute the JSON stream.
run_test_json() {
    local desc="$1"; shift
    local stdout_file stderr_file exit_code
    stdout_file="$TMPDIR_QA/_json_stdout.tmp"
    stderr_file="$TMPDIR_QA/_json_stderr.tmp"
    "$@" >"$stdout_file" 2>"$stderr_file" && exit_code=0 || exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        fail "$desc" "exit code $exit_code"
        cat "$stderr_file" 2>/dev/null | tail -5 | sed 's/^/         /'
        return 0
    fi
    if is_json_valid < "$stdout_file"; then
        pass "$desc"
        if $VERBOSE; then
            head -5 "$stdout_file" | sed 's/^/         /'
        fi
    else
        fail "$desc" "output is not valid JSON"
        head -5 "$stdout_file" | sed 's/^/         /'
    fi
    return 0
}

# run_test_output_contains "description" "substring" command [args...]
# Expects command to succeed and stdout to contain substring.
run_test_output_contains() {
    local desc="$1"; shift
    local substring="$1"; shift
    local output exit_code
    output=$("$@" 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -ne 0 ]]; then
        fail "$desc" "exit code $exit_code"
        printf '%s\n' "$output" | tail -5 | sed 's/^/         /'
        return 0
    fi
    if echo "$output" | grep -qi "$substring"; then
        pass "$desc"
    else
        fail "$desc" "output does not contain '$substring'"
        printf '%s\n' "$output" | head -10 | sed 's/^/         /'
    fi
    return 0
}

# run_test_file_exists "description" filepath
run_test_file_exists() {
    local desc="$1"
    local filepath="$2"
    if [[ -f "$filepath" && -s "$filepath" ]]; then
        pass "$desc"
    else
        fail "$desc" "file missing or empty: $filepath"
    fi
    return 0
}

# is_json_valid - reads stdin, validates JSON
is_json_valid() {
    if command -v jq &>/dev/null; then
        jq . >/dev/null 2>&1
    elif command -v python3 &>/dev/null; then
        python3 -m json.tool >/dev/null 2>&1
    else
        # No JSON validator available; assume valid
        cat >/dev/null
        return 0
    fi
}

# ---------------------------------------------------------------------------
# Group helpers
# ---------------------------------------------------------------------------
group_header() {
    printf '\n%s\n' "$(bold "=== $1 ===")"
}

should_run_group() {
    local name="$1"
    # If --group specified, only run those groups
    if [[ -n "$ONLY_GROUPS" ]]; then
        if ! echo ",$ONLY_GROUPS," | grep -q ",$name,"; then
            return 1
        fi
    fi
    # If --skip specified, exclude those groups
    if [[ -n "$SKIP_GROUPS" ]]; then
        if echo ",$SKIP_GROUPS," | grep -q ",$name,"; then
            return 1
        fi
    fi
    return 0
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --group)
                ONLY_GROUPS="$2"; shift 2 ;;
            --skip)
                SKIP_GROUPS="$2"; shift 2 ;;
            --list-groups)
                echo "Available test groups:"
                for g in $ALL_GROUPS; do
                    echo "  $g"
                done
                exit 0 ;;
            --no-color)
                NO_COLOR=true; shift ;;
            --verbose)
                VERBOSE=true; shift ;;
            --disk-threshold)
                DISK_THRESHOLD="$2"; shift 2 ;;
            --help|-h)
                head -38 "${BASH_SOURCE[0]}" | tail -35
                exit 0 ;;
            *)
                echo "Unknown option: $1" >&2
                exit 2 ;;
        esac
    done
}

# ---------------------------------------------------------------------------
# Setup & teardown
# ---------------------------------------------------------------------------
setup() {
    TMPDIR_QA=$(mktemp -d "${TMPDIR:-/tmp}/slicecore-qa.XXXXXX")
    trap cleanup EXIT
    printf '%s\n' "$(bold "slicecore CLI QA Tests")"
    printf 'Temp dir: %s\n' "$TMPDIR_QA"
    printf 'Project:  %s\n' "$PROJECT_ROOT"
}

cleanup() {
    if [[ -n "$TMPDIR_QA" && -d "$TMPDIR_QA" ]]; then
        if [[ $FAIL_COUNT -eq 0 ]]; then
            rm -rf "$TMPDIR_QA"
        else
            printf '\n  %s Temp dir preserved for debugging: %s\n' \
                "$(yellow "NOTE")" "$TMPDIR_QA"
        fi
    fi
}

# report_stale_qa_dirs - list old slicecore-qa.* temp dirs from previous runs
report_stale_qa_dirs() {
    local tmpbase="${TMPDIR:-/tmp}"
    local stale_dirs
    stale_dirs=$(find "$tmpbase" -maxdepth 1 -name "slicecore-qa.*" -type d \
        ! -path "$TMPDIR_QA" 2>/dev/null || true)

    if [[ -z "$stale_dirs" ]]; then
        return 0
    fi

    local count=0
    local total_kb=0
    while IFS= read -r d; do
        [[ -z "$d" ]] && continue
        count=$((count + 1))
        local kb
        kb=$(du -sk "$d" 2>/dev/null | awk '{print $1}')
        total_kb=$((total_kb + kb))
    done <<< "$stale_dirs"

    if [[ $count -gt 0 ]]; then
        local total_mb=$(( (total_kb + 512) / 1024 ))
        printf '\n  %s %d stale QA temp dir(s) found (%d MB):\n' \
            "$(yellow "NOTE")" "$count" "$total_mb"
        while IFS= read -r d; do
            [[ -z "$d" ]] && continue
            local kb
            kb=$(du -sk "$d" 2>/dev/null | awk '{print $1}')
            local mb=$(( (kb + 512) / 1024 ))
            local age
            age=$(find "$d" -maxdepth 0 -printf '%Ts\n' 2>/dev/null || stat -c '%Y' "$d" 2>/dev/null || echo "0")
            local now
            now=$(date +%s)
            local age_hrs=$(( (now - age) / 3600 ))
            printf '    %s  (%d MB, %d hours old)\n' "$d" "$mb" "$age_hrs"
        done <<< "$stale_dirs"
        printf '  To remove: rm -rf %s/slicecore-qa.*\n' "$tmpbase"
    fi
}

# ---------------------------------------------------------------------------
# Ensure slicecore binary
# ---------------------------------------------------------------------------
ensure_binary() {
    if [[ -n "$SLICECORE" && -x "$SLICECORE" ]]; then
        info "Using pre-set SLICECORE_BIN: $SLICECORE"
        return 0
    fi

    # After build group, use debug binary
    local debug_bin="$PROJECT_ROOT/target/debug/slicecore"
    local release_bin="$PROJECT_ROOT/target/release/slicecore"

    if [[ -x "$release_bin" ]]; then
        SLICECORE="$release_bin"
    elif [[ -x "$debug_bin" ]]; then
        SLICECORE="$debug_bin"
    else
        fail "No slicecore binary found. Run with --group build or set SLICECORE_BIN"
        return 1
    fi
    info "Using binary: $SLICECORE"
    return 0
}

# ---------------------------------------------------------------------------
# Disk space management
# ---------------------------------------------------------------------------

# get_disk_usage_percent - returns current disk usage percent for PROJECT_ROOT
get_disk_usage_percent() {
    df "$PROJECT_ROOT" | awk 'NR==2 {gsub(/%/,""); print $5}'
}

# get_target_size_mb - returns target/ dir size in MB (0 if absent)
get_target_size_mb() {
    if [[ -d "$PROJECT_ROOT/target" ]]; then
        du -sm "$PROJECT_ROOT/target" 2>/dev/null | awk '{print $1}'
    else
        echo "0"
    fi
}

# check_disk_space - check disk usage and clean if above threshold
# Called before build and after all tests complete.
check_disk_space() {
    local phase="$1"  # "pre-build" or "post-test"
    local usage
    usage=$(get_disk_usage_percent)
    local target_mb
    target_mb=$(get_target_size_mb)

    info "Disk: ${usage}% used, target/ is ${target_mb}MB (threshold: ${DISK_THRESHOLD}%)"

    if [[ "$usage" -ge "$DISK_THRESHOLD" ]]; then
        warn "Disk usage ${usage}% >= threshold ${DISK_THRESHOLD}%"

        # Try cargo-cache first (trims old artifacts, keeps recent cache)
        if command -v cargo-cache &>/dev/null; then
            info "Running cargo cache --autoclean..."
            cargo cache --autoclean 2>/dev/null || true
            usage=$(get_disk_usage_percent)
            info "Disk after cargo-cache: ${usage}%"
        fi

        # If still above threshold, fall back to cargo clean
        if [[ "$usage" -ge "$DISK_THRESHOLD" ]]; then
            if [[ "$phase" == "pre-build" ]]; then
                warn "Running cargo clean to free space before build..."
                cargo clean 2>/dev/null || true
                usage=$(get_disk_usage_percent)
                info "Disk after cargo clean: ${usage}%"
            else
                warn "Disk still above threshold. Run 'cargo clean' manually to reclaim space."
            fi
        fi

        # Final check -- if still critically full (>= 98%), abort
        usage=$(get_disk_usage_percent)
        if [[ "$usage" -ge 98 ]]; then
            fail "Disk critically full (${usage}%). Cannot proceed."
            return 1
        fi
    fi
    return 0
}

# ---------------------------------------------------------------------------
# Fixture generation
# ---------------------------------------------------------------------------
generate_fixtures() {
    group_header "Fixture Generation"

    if ! ensure_binary; then
        fail "Cannot generate fixtures without binary"
        return 1
    fi

    # Generate primitives
    run_test "Generate cube.stl primitive" \
        "$SLICECORE" csg primitive box --dims 20 20 20 -o "$TMPDIR_QA/cube.stl"

    run_test "Generate sphere.stl primitive" \
        "$SLICECORE" csg primitive sphere --dims 10 -o "$TMPDIR_QA/sphere.stl"

    run_test "Generate cylinder.stl primitive" \
        "$SLICECORE" csg primitive cylinder --dims 5 20 -o "$TMPDIR_QA/cylinder.stl"

    # Convert to other formats
    run_test "Convert cube.stl -> cube.3mf" \
        "$SLICECORE" convert "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/cube.3mf"

    run_test "Convert cube.stl -> cube.obj" \
        "$SLICECORE" convert "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/cube.obj"

    # Slice to get gcode fixtures
    run_test "Slice cube.stl -> cube.gcode" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" -o "$TMPDIR_QA/cube.gcode"

    run_test "Slice sphere.stl -> sphere.gcode" \
        "$SLICECORE" slice "$TMPDIR_QA/sphere.stl" -o "$TMPDIR_QA/sphere.gcode"

    # Verify key fixtures exist
    for f in cube.stl sphere.stl cylinder.stl cube.3mf cube.obj cube.gcode sphere.gcode; do
        if [[ ! -f "$TMPDIR_QA/$f" ]]; then
            fail "Fixture $f not generated"
            return 1
        fi
    done
    info "All fixtures generated successfully"
    return 0
}

# ---------------------------------------------------------------------------
# GROUP: build
# ---------------------------------------------------------------------------
group_build() {
    should_run_group "build" || return 0
    group_header "Build Gates"

    cd "$PROJECT_ROOT"

    run_test "cargo build --workspace" \
        cargo build --workspace

    # Set binary path after successful build
    if [[ -z "$SLICECORE" ]]; then
        SLICECORE="$PROJECT_ROOT/target/debug/slicecore"
    fi

    run_test "cargo fmt --all -- --check" \
        cargo fmt --all -- --check

    run_test "cargo clippy --all-features -- -D warnings" \
        cargo clippy --all-features -- -D warnings

    run_test "cargo test --all-features --workspace" \
        cargo test --all-features --workspace

    RUSTDOCFLAGS="-D warnings" \
    run_test "cargo doc --no-deps --workspace" \
        cargo doc --no-deps --workspace
}

# ---------------------------------------------------------------------------
# GROUP: bench
# ---------------------------------------------------------------------------
group_bench() {
    should_run_group "bench" || return 0
    group_header "Benchmarks"

    cd "$PROJECT_ROOT"

    run_test "cargo bench --workspace" \
        cargo bench --workspace
}

# ---------------------------------------------------------------------------
# GROUP: mesh
# ---------------------------------------------------------------------------
group_mesh() {
    should_run_group "mesh" || return 0
    group_header "Mesh Analysis"

    run_test_output_contains "analyze cube.stl" "triangles\|vertices\|Triangles\|Vertices" \
        "$SLICECORE" analyze "$TMPDIR_QA/cube.stl"

    run_test "analyze cube.3mf" \
        "$SLICECORE" analyze "$TMPDIR_QA/cube.3mf"

    run_test "analyze cube.obj" \
        "$SLICECORE" analyze "$TMPDIR_QA/cube.obj"
}

# ---------------------------------------------------------------------------
# GROUP: slice
# ---------------------------------------------------------------------------
group_slice() {
    should_run_group "slice" || return 0
    group_header "Slicing"

    run_test "slice cube.stl to gcode" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" -o "$TMPDIR_QA/test_slice.gcode"
    run_test_file_exists "slice output file exists" "$TMPDIR_QA/test_slice.gcode"

    run_test_json "slice cube.stl --json" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --json -o "$TMPDIR_QA/json_out.gcode"

    run_test "slice cube.3mf to gcode" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.3mf" -o "$TMPDIR_QA/test_3mf.gcode"

    run_test "slice with --stats-format csv --quiet" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --stats-format csv --quiet -o "$TMPDIR_QA/csv_test.gcode"

    run_test "slice with --stats-format json --quiet" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --stats-format json --quiet -o "$TMPDIR_QA/json_test.gcode"

    run_test "slice with --thumbnails" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --thumbnails -o "$TMPDIR_QA/thumb_slice.gcode"
}

# ---------------------------------------------------------------------------
# GROUP: travel-opt
# ---------------------------------------------------------------------------
group_travel_opt() {
    should_run_group "travel-opt" || return 0
    group_header "Travel Optimization Flags"

    run_test "slice with --no-travel-opt" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --no-travel-opt -o "$TMPDIR_QA/no_travel.gcode"

    run_test_file_exists "no-travel-opt output exists" "$TMPDIR_QA/no_travel.gcode"

    run_test "slice default (travel opt enabled)" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" -o "$TMPDIR_QA/with_travel.gcode"
}

# ---------------------------------------------------------------------------
# GROUP: global-flags
# ---------------------------------------------------------------------------
group_global_flags() {
    should_run_group "global-flags" || return 0
    group_header "Global Flags (--quiet, --color, --json)"

    run_test "slice --quiet suppresses progress" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --quiet -o "$TMPDIR_QA/quiet_out.gcode"

    run_test "analyze --quiet" \
        "$SLICECORE" analyze "$TMPDIR_QA/cube.stl" --quiet

    run_test "slice --color never" \
        "$SLICECORE" slice "$TMPDIR_QA/cube.stl" --color never -o "$TMPDIR_QA/nocolor.gcode"

    # Create test_profile.json fixture inline (group_profile may not have run)
    cat > "$TMPDIR_QA/test_profile_gf.json" << 'JSONEOF'
    {
      "layer_height": "0.2",
      "wall_loops": "3",
      "sparse_infill_density": "15%",
      "nozzle_temperature": ["220"],
      "hot_plate_temp": ["60"]
    }
JSONEOF

    run_test_json "convert-profile --json" \
        "$SLICECORE" convert-profile "$TMPDIR_QA/test_profile_gf.json" --json -o "$TMPDIR_QA/converted_json.toml"
}

# ---------------------------------------------------------------------------
# GROUP: gcode
# ---------------------------------------------------------------------------
group_gcode() {
    should_run_group "gcode" || return 0
    group_header "G-code Operations"

    run_test "validate cube.gcode" \
        "$SLICECORE" validate "$TMPDIR_QA/cube.gcode"

    run_test "analyze-gcode cube.gcode" \
        "$SLICECORE" analyze-gcode "$TMPDIR_QA/cube.gcode"

    run_test_json "analyze-gcode --json" \
        "$SLICECORE" analyze-gcode "$TMPDIR_QA/cube.gcode" --json

    run_test "analyze-gcode --csv" \
        "$SLICECORE" analyze-gcode "$TMPDIR_QA/cube.gcode" --csv

    run_test "analyze-gcode --summary" \
        "$SLICECORE" analyze-gcode "$TMPDIR_QA/cube.gcode" --summary

    run_test "analyze-gcode --no-color" \
        "$SLICECORE" analyze-gcode "$TMPDIR_QA/cube.gcode" --no-color

    run_test "compare-gcode cube vs sphere" \
        "$SLICECORE" compare-gcode "$TMPDIR_QA/cube.gcode" "$TMPDIR_QA/sphere.gcode"

    run_test_json "compare-gcode --json" \
        "$SLICECORE" compare-gcode "$TMPDIR_QA/cube.gcode" "$TMPDIR_QA/sphere.gcode" --json

    run_test "compare-gcode --csv" \
        "$SLICECORE" compare-gcode "$TMPDIR_QA/cube.gcode" "$TMPDIR_QA/sphere.gcode" --csv
}

# ---------------------------------------------------------------------------
# GROUP: csg
# ---------------------------------------------------------------------------
group_csg() {
    should_run_group "csg" || return 0
    group_header "CSG Operations"

    # Boolean operations
    run_test "csg union" \
        "$SLICECORE" csg union "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" -o "$TMPDIR_QA/union.stl"

    run_test "csg difference" \
        "$SLICECORE" csg difference "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" -o "$TMPDIR_QA/diff.stl"

    run_test "csg intersection" \
        "$SLICECORE" csg intersection "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" -o "$TMPDIR_QA/inter.stl"

    run_test "csg xor" \
        "$SLICECORE" csg xor "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" -o "$TMPDIR_QA/xor.stl"

    # Split
    run_test "csg split" \
        "$SLICECORE" csg split "$TMPDIR_QA/cube.stl" --plane "0,0,1,10" \
        -o "$TMPDIR_QA/above.stl" "$TMPDIR_QA/below.stl"

    # Hollow
    run_test "csg hollow" \
        "$SLICECORE" csg hollow "$TMPDIR_QA/cube.stl" --wall 2.0 -o "$TMPDIR_QA/hollow.stl"

    run_test "csg hollow with drain" \
        "$SLICECORE" csg hollow "$TMPDIR_QA/cube.stl" --wall 2.0 --drain-diameter 5.0 \
        -o "$TMPDIR_QA/hollow_drain.stl"

    # Info
    run_test "csg info" \
        "$SLICECORE" csg info "$TMPDIR_QA/cube.stl"

    run_test_json "csg info --json" \
        "$SLICECORE" csg info "$TMPDIR_QA/cube.stl" --json

    # Boolean ops with --json
    run_test_json "csg union --json" \
        "$SLICECORE" csg union "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/union_j.stl" --json

    run_test_json "csg difference --json" \
        "$SLICECORE" csg difference "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/diff_j.stl" --json

    run_test_json "csg intersection --json" \
        "$SLICECORE" csg intersection "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/inter_j.stl" --json

    run_test_json "csg xor --json" \
        "$SLICECORE" csg xor "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/xor_j.stl" --json

    # Boolean ops with --verbose
    run_test "csg union --verbose" \
        "$SLICECORE" csg union "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/union_v.stl" --verbose

    run_test "csg difference --verbose" \
        "$SLICECORE" csg difference "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/diff_v.stl" --verbose

    run_test "csg intersection --verbose" \
        "$SLICECORE" csg intersection "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/inter_v.stl" --verbose

    run_test "csg xor --verbose" \
        "$SLICECORE" csg xor "$TMPDIR_QA/cube.stl" "$TMPDIR_QA/sphere.stl" \
        -o "$TMPDIR_QA/xor_v.stl" --verbose

    # Primitive generation (all shapes)
    local -a shapes=("box" "sphere" "cylinder" "cone" "torus" "wedge" "ngon-prism")
    local -a dims=("10 10 10" "8" "5 15" "5 15" "8 3" "10 10 10" "6 5 15")

    for i in "${!shapes[@]}"; do
        local shape="${shapes[$i]}"
        local dim="${dims[$i]}"
        # shellcheck disable=SC2086
        run_test "csg primitive $shape" \
            "$SLICECORE" csg primitive "$shape" --dims $dim -o "$TMPDIR_QA/prim_${shape}.stl"
    done
}

