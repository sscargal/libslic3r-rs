# ---------------------------------------------------------------------------
# GROUP: profile
# ---------------------------------------------------------------------------
group_profile() {
    should_run_group "profile" || return 0
    group_header "Profile Commands"

    # These may fail if no profiles directory is configured
    local output exit_code

    output=$("$SLICECORE" list-profiles --vendors 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        pass "list-profiles --vendors"
    else
        warn "list-profiles --vendors (no profiles directory or other issue)"
    fi

    output=$("$SLICECORE" list-profiles 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        pass "list-profiles"
    else
        warn "list-profiles (no profiles directory or other issue)"
    fi

    output=$("$SLICECORE" search-profiles "PLA" 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        pass "search-profiles PLA"
    else
        warn "search-profiles PLA (no profiles directory or other issue)"
    fi

    # show-profile (may fail without profiles directory)
    output=$("$SLICECORE" show-profile "test/vendor/filament/PLA" 2>&1) && exit_code=0 || exit_code=$?
    if [[ $exit_code -eq 0 ]]; then
        pass "show-profile"
    else
        warn "show-profile (no profiles directory or other issue)"
    fi

    # convert-profile: create a minimal JSON fixture and convert to TOML
    cat > "$TMPDIR_QA/test_profile.json" << 'JSONEOF'
    {
      "layer_height": "0.2",
      "wall_loops": "3",
      "sparse_infill_density": "15%",
      "nozzle_temperature": ["220"],
      "hot_plate_temp": ["60"]
    }
JSONEOF

    run_test "convert-profile JSON to TOML" \
        "$SLICECORE" convert-profile "$TMPDIR_QA/test_profile.json" -o "$TMPDIR_QA/converted.toml"

    run_test_file_exists "converted TOML exists" "$TMPDIR_QA/converted.toml"

    run_test "convert-profile verbose" \
        "$SLICECORE" convert-profile "$TMPDIR_QA/test_profile.json" -v -o "$TMPDIR_QA/converted_v.toml"
}

